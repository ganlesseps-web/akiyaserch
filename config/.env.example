# Discord 通知 Webhook URL
# Discord サーバー設定 > 連携サービス > ウェブフック で発行
DISCORD_WEBHOOK_URL=

# Google Maps Distance Matrix API (境界府県の2時間判定用、後で追加)
# https://console.cloud.google.com/ で取得、Distance Matrix API を有効化
GOOGLE_MAPS_API_KEY=

# SQLite ファイルパス（デフォルト: data/properties.db）
TRADE_DB_PATH=data/properties.db

# scrape / notify のログ出力先（空ならstderr）
TRADE_LOG_PATH=
