# === ストレージ ===
# Turso (libsql) を使う場合は設定。未設定なら ローカル SQLite (data/properties.db) を使う。
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === 通知 ===
# Discord 通知 Webhook URL
# Discord サーバー設定 > 連携サービス > ウェブフック で発行
DISCORD_WEBHOOK_URL=

# === ダッシュボード Basic 認証 ===
# 両方設定すると / にアクセスする際に Basic 認証を要求する。
# Vercel に Deploy する際は必ず設定すること (公開URL なので)。
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# === オプション ===
# Google Maps Distance Matrix API (境界府県の2時間判定用、後で追加)
# https://console.cloud.google.com/ で取得、Distance Matrix API を有効化
GOOGLE_MAPS_API_KEY=

# SQLite ファイルパス（デフォルト: data/properties.db）— Turso 未使用時のみ有効
TRADE_DB_PATH=

# scrape / notify のログ出力先（空ならstderr）
TRADE_LOG_PATH=
